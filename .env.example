MP_ACCESS_TOKEN_EVIDENCIA=APP_USR-TU-TOKEN-AQUI
MP_PUBLIC_KEY_EVIDENCIA=APP_USR-TU-CLAVE-PUBLICA-AQUI

# ── PayPal — por sitio ────────────────────────────────────────────────────────
